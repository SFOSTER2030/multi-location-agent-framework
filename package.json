{
    "name": "multi-location-agent-framework",
    "private": false,
    "version": "2.1.0",
    "type": "module",
    "description": "Deploy and manage AI agents across distributed business locations — franchise systems, PE portfolios, multi-office professional services.",
    "keywords": [
          "ai-agents",
          "multi-location",
          "franchise-automation",
          "operational-intelligence",
          "agentic-infrastructure",
          "supabase",
          "react",
          "typescript"
    ],
    "author": "TFSF Ventures FZ-LLC",
    "license": "MIT",
    "scripts": {
          "dev": "vite",
          "build": "tsc && vite build",
          "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
          "lint:fix": "eslint . --ext ts,tsx --fix",
          "type-check": "tsc --noEmit",
          "preview": "vite preview",
          "test": "vitest run",
          "test:watch": "vitest"
    },
    "dependencies": {
          "@supabase/supabase-js": "^2.45.0",
          "@tanstack/react-query": "^5.56.0",
          "date-fns": "^3.6.0",
          "lucide-react": "^0.383.0",
          "react": "^18.3.1",
          "react-dom": "^18.3.1",
          "react-router-dom": "^6.26.0",
          "recharts": "^2.12.7",
          "zustand": "^4.5.4"
    },
    "devDependencies": {
          "@types/react": "^18.3.3",
          "@types/react-dom": "^18.3.0",
          "@typescript-eslint/eslint-plugin": "^7.18.0",
          "@typescript-eslint/parser": "^7.18.0",
          "@vitejs/plugin-react": "^4.3.1",
          "autoprefixer": "^10.4.19",
          "eslint": "^8.57.0",
          "eslint-plugin-react-hooks": "^4.6.2",
          "eslint-plugin-react-refresh": "^0.4.9",
          "postcss": "^8.4.40",
          "tailwindcss": "^3.4.7",
          "typescript": "^5.5.3",
          "vite": "^5.4.0",
          "vitest": "^2.0.5"
    },
    "engines": {
          "node": ">=18.0.0"
    }
}
